    {
      "parameters": {
        "fromEmail": "incidents@company.com",
        "subject": "Incident {{ $json.incidentId }} Acknowledged",
        "text": "Your incident has been logged and assigned to our team.\n\nIncident Details:\n- ID: {{ $json.incidentId }}\n- Title: {{ $json.title }}\n- Service: {{ $json.service }}\n- Severity: {{ $json.severity }}\n- Environment: {{ $json.environment }}\n\nExpected Response Times:\n- P2: 4 hours\n- P3: 8 hours\n\nYou will receive updates as we investigate and resolve this issue.\n\nTicket: {{ $('Create P2P3 Ticket').item.json.key }}",
        "toEmail": "={{ $json.requesterEmail }}"
      },
