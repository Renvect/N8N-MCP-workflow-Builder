          "slackMessageTs": "={{ $('Send Slack Alert P0P1').item.json.ts || null }}",
          "ticketKey": "={{ $('Create Jira Ticket').item.json.key || $('Create P2P3 Ticket').item.json.key || null }}"
        },
        "operation": "insert",
        "tableId": "incident_runs"
      },
      "id": "61d49ab2-8e78-4fd6-a98c-91e37c037c4a",
      "name": "Log to Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
